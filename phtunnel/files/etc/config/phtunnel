# PHTunnel Configuration

config base 'base'
	# Enable PHTunnel service
	option enabled '0'

	# Configuration file path (will be generated by the service)
	option config_file '/etc/phtunnel.json'

	# Application ID (optional, for custom account)
	option app_id ''

	# Application Key (optional, for custom account)
	option app_key ''

	# Server address
	option server 'https://hsk-embed.oray.com'

	# PID file path
	option pid_file '/tmp/phtunnel.pid'

config log 'log'
	# Log file path
	option path '/var/log/oraybox/phtunnel.log'
